# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL (e.g., https://xxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=

# Site URL (for email redirects in production)
# For local development, this will default to http://localhost:5173
# For production, set this to your deployed URL (e.g., https://yourdomain.com)
VITE_SITE_URL=

# Backend API — CLIP/UnivFD detection (catches DALL-E 3, Midjourney, FLUX)
# Option 1 — run locally:
#   scripts/.venv312/Scripts/uvicorn backend.main:app --reload --port 8787
# Option 2 — deploy free to Modal.com:
#   pip install modal && modal deploy backend/modal_app.py
#   Then set this to your Modal URL: https://your-username--deepfake-detect-api.modal.run
# Leave blank to disable (app works without it, just less coverage on new generators)
VITE_BACKEND_URL=http://localhost:8787
